# PayLater App - Production Environment Variables
# Copy this file to .env.local for local development
# Add these variables to Vercel dashboard for production

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Google OAuth (configured in Supabase dashboard - Authentication > Providers > Google)
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET are set in Supabase project settings, not here

# Next.js Configuration
NEXTAUTH_SECRET="your-super-secret-production-key-min-32-chars"

# Optional: Analytics and Monitoring
# VERCEL_ANALYTICS_ID="your-analytics-id"
# SENTRY_DSN="your-sentry-dsn"
